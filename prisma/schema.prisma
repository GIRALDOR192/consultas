generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  OPERATOR
  ASSISTANT
}

enum ProcessStatus {
  PENDING
  PAYMENT_RECEIVED
  PREPARATION
  IN_PROGRESS
  SEALED
  COMPLETED
  PAUSED
  CANCELLED
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum UploadType {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  PAYMENT_PROOF
}

enum QuestionType {
  MULTIPLE_CHOICE
  SHORT_TEXT
  LONG_TEXT
  EMOTIONAL_SLIDER
  EMOJI_SCALE
  OPEN
}

enum NotificationType {
  STATUS_CHANGE
  NEW_UPDATE
  SURVEY_READY
  REMINDER
  SYSTEM
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String
  name        String
  role        Role     @default(ASSISTANT)
  isActive    Boolean  @default(true)
  lastLogin   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  processes         Process[]     @relation("AssignedWorker")
  processUpdates    ProcessUpdate[]
  activityLogs      ActivityLog[]
  surveyCreated     Survey[]

  @@map("users")
}

model Client {
  id          String   @id @default(cuid())
  name        String
  email       String?
  phone       String?
  birthDate   DateTime?
  notes       String?
  tags        String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  processes   Process[]

  @@map("clients")
}

model Process {
  id              String        @id @default(cuid())
  token           String        @unique @default(cuid()) // token URL-safe
  secureToken     String        @unique                  // token cifrado largo
  clientId        String
  assignedUserId  String?
  workName        String        // nombre del trabajo (libre)
  description     String?       // descripción privada
  price           Decimal       @db.Decimal(10,2)
  currency        String        @default("MXN")
  status          ProcessStatus @default(PENDING)
  priority        Priority      @default(NORMAL)
  estimatedDays   Int?
  progressPercent Int           @default(0)
  r2Directory     String        @unique // directorio cifrado en R2
  tokenExpiry     DateTime?     // opcional: expiración de acceso
  trackingEnabled Boolean       @default(true)
  surveysEnabled  Boolean       @default(true)
  adminNotes      String?       // notas internas admin
  clientMessage   String?       // mensaje de bienvenida personalizado
  pendingPaymentAmount Decimal?      @db.Decimal(10,2)
  pendingPaymentDate   DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  client          Client        @relation(fields: [clientId], references: [id])
  assignedUser    User?         @relation("AssignedWorker", fields: [assignedUserId], references: [id])
  updates         ProcessUpdate[]
  uploads         Upload[]
  surveys         Survey[]
  surveyAnswers   SurveyAnswer[]
  emotionalLogs   EmotionalLog[]
  payments        Payment[]
  notifications   Notification[]
  clientLastSeen  DateTime?     // última vez que el cliente accedió al portal
  clientForm      ClientForm?
  notes           ProcessNote[]
  tags            ProcessTag[]
  ritualizations  Ritualization[]

  @@index([token])
  @@index([secureToken])
  @@index([status])
  @@index([clientId])
  @@map("processes")
}

model ProcessUpdate {
  id          String   @id @default(cuid())
  processId   String
  authorId    String
  title       String?
  content     String
  isPublic    Boolean  @default(true) // visible para el cliente
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())

  process     Process  @relation(fields: [processId], references: [id], onDelete: Cascade)
  author      User     @relation(fields: [authorId], references: [id])
  uploads     Upload[]

  @@index([processId])
  @@map("process_updates")
}

model ClientForm {
  id              String   @id @default(cuid())
  processId       String   @unique
  fullName        String
  birthDate       DateTime?
  fullName2       String?
  birthDate2      DateTime?
  intention       String
  currentSituation String
  additionalInfo  String?
  submittedAt     DateTime @default(now())
  updatedAt       DateTime @updatedAt

  process         Process  @relation(fields: [processId], references: [id], onDelete: Cascade)

  @@map("client_forms")
}

model Upload {
  id              String     @id @default(cuid())
  processId       String
  processUpdateId String?
  uploadedBy      String?    // null si es el cliente
  r2Key           String     @unique
  r2Bucket        String
  fileName        String
  fileType        UploadType
  mimeType        String
  fileSizeBytes   Int
  isPublic        Boolean    @default(false)
  isPaymentProof  Boolean    @default(false)
  metadata        String?    @db.Text
  createdAt       DateTime   @default(now())

  process         Process      @relation(fields: [processId], references: [id], onDelete: Cascade)
  processUpdate   ProcessUpdate? @relation(fields: [processUpdateId], references: [id])

  @@index([processId])
  @@index([r2Key])
  @@map("uploads")
}

model Survey {
  id          String   @id @default(cuid())
  processId   String
  createdById String
  title       String
  description String?
  isActive    Boolean  @default(true)
  dueDate     DateTime?
  createdAt   DateTime @default(now())

  process     Process          @relation(fields: [processId], references: [id], onDelete: Cascade)
  createdBy   User             @relation(fields: [createdById], references: [id])
  questions   SurveyQuestion[]
  answers     SurveyAnswer[]

  @@map("surveys")
}

model SurveyQuestion {
  id          String       @id @default(cuid())
  surveyId    String
  text        String
  type        QuestionType
  options     String?      @db.Text  // para múltiple opción, guardado como stringified JSON
  orderIndex  Int          @default(0)
  isRequired  Boolean      @default(false)
  createdAt   DateTime     @default(now())

  survey      Survey         @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  answers     SurveyAnswer[]

  @@map("survey_questions")
}

model SurveyAnswer {
  id          String   @id @default(cuid())
  surveyId    String
  processId   String
  questionId  String
  answer      String   @db.Text  // flexible: texto, número, array (stringified JSON)
  submittedAt DateTime @default(now())

  survey      Survey         @relation(fields: [surveyId], references: [id])
  process     Process        @relation(fields: [processId], references: [id])
  question    SurveyQuestion @relation(fields: [questionId], references: [id])

  @@map("survey_answers")
}

model EmotionalLog {
  id          String   @id @default(cuid())
  processId   String
  type        String   // dream, emotion, change, experience
  content     String
  mood        Int?     // 1-10
  tags        String[]
  logDate     DateTime @default(now())
  createdAt   DateTime @default(now())

  process     Process  @relation(fields: [processId], references: [id], onDelete: Cascade)

  @@index([processId])
  @@map("emotional_logs")
}

model Payment {
  id          String   @id @default(cuid())
  processId   String
  amount      Decimal  @db.Decimal(10,2)
  currency    String   @default("MXN")
  method      String?
  reference   String?
  status      String   @default("pending") // pending, confirmed, rejected
  proofUrl    String?
  notes       String?
  paidAt      DateTime?
  createdAt   DateTime @default(now())

  process     Process  @relation(fields: [processId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Notification {
  id          String           @id @default(cuid())
  processId   String
  type        NotificationType
  title       String
  message     String
  isRead      Boolean          @default(false)
  metadata    String?          @db.Text // JSON stringified
  createdAt   DateTime         @default(now())

  process     Process          @relation(fields: [processId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model ProcessNote {
  id          String   @id @default(cuid())
  processId   String
  content     String
  isPinned    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  process     Process  @relation(fields: [processId], references: [id], onDelete: Cascade)

  @@map("process_notes")
}

model ProcessTag {
  id          String   @id @default(cuid())
  processId   String
  label       String
  color       String   @default("#6B4FA0")

  process     Process  @relation(fields: [processId], references: [id], onDelete: Cascade)

  @@map("process_tags")
}

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String
  entity      String
  entityId    String?
  metadata    String?  @db.Text // JSON stringified
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity, entityId])
  @@map("activity_logs")
}

model Ritualization {
  id          String    @id @default(cuid())
  processId   String
  name        String    // Nombre del ritual / ritualización
  notes       String?   // Anotaciones internas sobre este ritual
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  orderIndex  Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  process     Process   @relation(fields: [processId], references: [id], onDelete: Cascade)

  @@index([processId])
  @@map("ritualizations")
}
